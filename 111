/*
节点入口/落地对比 for Quantumult X
版本：v3 - 剪贴板辅助方案

工作流：
1. 在 QX 节点列表点开目标节点，复制 server 字段（域名或 IP）
2. 风车 → 任务 → 执行本脚本
3. 脚本读取剪贴板的 server 作为入口查询，当前代理出口作为落地查询

配置（加到 [task_local]）：
event-interaction https://你的链接/node_path_check.js, tag=节点链路分析, img-url=globe.americas.fill.system, enabled=true

依赖：
- $task.fetch 支持 opts.policy = "direct" 强制直连
- $clipboard 读取剪贴板
*/

const $ = {
  notify: (title, subtitle, body) => $notify(title, subtitle, body),
  done: () => $done(),
};

// ========== 工具 ==========

function isIPv4(s) {
  return /^(\d{1,3}\.){3}\d{1,3}$/.test(s || "");
}
function isIPv6(s) {
  return /:/.test(s || "") && /^[0-9a-fA-F:]+$/.test(s);
}
function isIP(s) {
  return isIPv4(s) || isIPv6(s);
}

// 从剪贴板内容提取可能的 server 字段
// 支持直接粘整行 server=xxx:port 或者只粘域名/IP
function extractServer(raw) {
  if (!raw) return null;
  const text = String(raw).trim();

  // 形如 server=xxx 或 server = xxx
  const m1 = text.match(/server\s*=\s*([^\s,]+)/i);
  if (m1) return m1[1].split(":")[0].replace(/^\[|\]$/g, "");

  // 形如 vmess=host:port, ... 或 trojan=host:port, ...
  const m2 = text.match(/^[a-z]+\s*=\s*([^:,\s]+)/i);
  if (m2) return m2[1];

  // 单纯一个域名/IP（可能带端口）
  const first = text.split(/[\s,]/)[0];
  return first.split(":")[0].replace(/^\[|\]$/g, "");
}

// 直连 DoH 解析域名
function resolveDirectly(host) {
  return new Promise((resolve) => {
    if (isIP(host)) {
      resolve(host);
      return;
    }
    $task.fetch({
      url: `https://1.1.1.1/dns-query?name=${encodeURIComponent(host)}&type=A`,
      method: "GET",
      headers: { Accept: "application/dns-json" },
      timeout: 5000,
      opts: { policy: "direct" },
    }).then(
      (resp) => {
        try {
          const data = JSON.parse(resp.body);
          const a = (data.Answer || []).find((r) => r.type === 1);
          resolve(a ? a.data : host);
        } catch (e) {
          resolve(host);
        }
      },
      () => resolve(host)
    );
  });
}

// 查询某个 IP 的信息（直连）
function queryIPDirect(ip) {
  return new Promise((resolve) => {
    $task.fetch({
      url: `http://ip-api.com/json/${encodeURIComponent(
        ip
      )}?lang=zh-CN&fields=status,message,country,regionName,city,isp,org,as,query,hosting,proxy`,
      method: "GET",
      timeout: 6000,
      opts: { policy: "direct" },
    }).then(
      (resp) => {
        try {
          resolve(JSON.parse(resp.body));
        } catch (e) {
          resolve(null);
        }
      },
      () => resolve(null)
    );
  });
}

// 查询当前出口（走当前代理，不指定 policy 即默认走主策略）
function queryExit() {
  return new Promise((resolve) => {
    $task.fetch({
      url: `http://ip-api.com/json/?lang=zh-CN&fields=status,country,regionName,city,isp,org,as,query,hosting,proxy`,
      method: "GET",
      timeout: 8000,
    }).then(
      (resp) => {
        try {
          resolve(JSON.parse(resp.body));
        } catch (e) {
          resolve(null);
        }
      },
      () => resolve(null)
    );
  });
}

function shortASN(asField) {
  if (!asField) return "未知";
  const m = asField.match(/^AS\d+/);
  if (!m) return asField;
  const rest = asField.slice(m[0].length).trim().replace(/^,?\s*/, "");
  return `${m[0]} ${rest}`;
}

function tagsOf(info) {
  const t = [];
  if (info.hosting) t.push("机房");
  if (info.proxy) t.push("代理标记");
  return t.length ? t.join(" / ") : null;
}

function formatBlock(label, info, originalHost) {
  if (!info || info.status !== "success") {
    return [
      label,
      `  地址：${originalHost || "—"}`,
      `  状态：查询失败${info && info.message ? ` (${info.message})` : ""}`,
    ].join("\n");
  }
  const lines = [label];
  const showHost =
    originalHost && originalHost !== info.query
      ? `${info.query}  ←  ${originalHost}`
      : info.query;
  lines.push(`  IP：${showHost}`);
  lines.push(
    `  位置：${info.country || "?"} / ${info.regionName || "?"} / ${
      info.city || "?"
    }`
  );
  lines.push(`  运营商：${info.isp || "未知"}`);
  lines.push(`  ASN：${shortASN(info.as)}`);
  const t = tagsOf(info);
  if (t) lines.push(`  标签：${t}`);
  return lines.join("\n");
}

function judge(entry, exit) {
  if (!entry || !exit) return "❓ 数据不全，无法判断";
  if (entry.status !== "success" || exit.status !== "success")
    return "❓ 查询失败，无法判断";

  if (entry.query === exit.query) return "✅ 直连落地（入口 IP = 出口 IP）";

  const eAS = (entry.as || "").match(/^AS\d+/);
  const xAS = (exit.as || "").match(/^AS\d+/);
  const sameAS = eAS && xAS && eAS[0] === xAS[0];
  const sameCountry = entry.country === exit.country;

  if (sameAS) return "🟡 同 ASN 内中转（机场内部跳转或同云厂商）";
  if (sameCountry) return "🟠 同国家、不同 ASN 中转";
  return "🔴 跨国/跨运营商中转";
}

// ========== 主流程 ==========

async function main() {
  const clip = typeof $clipboard !== "undefined" ? $clipboard : null;
  const serverHost = extractServer(clip);

  if (!serverHost) {
    $.notify(
      "节点链路分析",
      "📋 剪贴板为空或无法识别",
      "请先在节点详情页长按复制 server 字段（域名或 IP），再执行本任务"
    );
    $.done();
    return;
  }

  // 1. 入口：解析 + 查询（强制直连）
  const entryIP = await resolveDirectly(serverHost);

  // 2. 并发跑入口查询和落地查询
  const [entryInfo, exitInfo] = await Promise.all([
    queryIPDirect(entryIP),
    queryExit(),
  ]);

  // 3. 组装通知
  const blocks = [
    formatBlock("📥 入口（来自剪贴板）", entryInfo, serverHost),
    formatBlock("📤 落地（当前代理出口）", exitInfo, null),
    "━━━━━━━━━━",
    judge(entryInfo, exitInfo),
  ];

  $.notify(
    "节点链路分析",
    `Server: ${serverHost}`,
    blocks.join("\n\n")
  );
  $.done();
}

main().catch((err) => {
  $.notify("节点链路分析", "❌ 脚本异常", String(err && err.message ? err.message : err));
  $.done();
});
